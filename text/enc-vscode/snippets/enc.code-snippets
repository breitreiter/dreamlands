{
  "Choice": {
    "prefix": ["choice", "* "],
    "body": [
      "* ${1:Link text} = ${2:Preview text}",
      "  ${0}"
    ],
    "description": "New choice with link = preview"
  },
  "If Check Block": {
    "prefix": ["if check", "@if check"],
    "body": [
      "@if check ${1|combat,negotiation,bushcraft,cunning,luck,mercantile|} ${2|medium,trivial,easy,hard,very_hard,heroic|} {",
      "  ${3:Success outcome}",
      "} @else {",
      "  ${4:Failure outcome}",
      "}"
    ],
    "description": "Skill check with success/failure branches"
  },
  "If Has Block": {
    "prefix": ["if has", "@if has"],
    "body": [
      "@if has ${1:item_id} {",
      "  ${2:Outcome when player has item}",
      "} @else {",
      "  ${3:Outcome otherwise}",
      "}"
    ],
    "description": "Branch on item possession"
  },
  "If Tag Block": {
    "prefix": ["if tag", "@if tag"],
    "body": [
      "@if tag ${1:tag_id} {",
      "  ${2:Outcome when tag is set}",
      "} @else {",
      "  ${3:Outcome otherwise}",
      "}"
    ],
    "description": "Branch on world-state tag"
  },
  "If Quality Block": {
    "prefix": ["if quality", "@if quality"],
    "body": [
      "@if quality ${1:quality_id} ${2:threshold} {",
      "  ${3:Outcome when quality meets threshold}",
      "} @else {",
      "  ${4:Outcome otherwise}",
      "}"
    ],
    "description": "Branch on quality value"
  },
  "If Meets Block": {
    "prefix": ["if meets", "@if meets"],
    "body": [
      "@if meets ${1|combat,negotiation,bushcraft,cunning,luck,mercantile|} ${2:target} {",
      "  ${3:Outcome when skill meets target}",
      "} @else {",
      "  ${4:Outcome otherwise}",
      "}"
    ],
    "description": "Branch on skill level"
  },
  "Requires": {
    "prefix": ["requires", "[requires"],
    "body": "[requires ${1|has,tag,check,quality,meets|} ${2:id}]",
    "description": "Gate a choice on a condition"
  },
  "Front-matter: trigger": {
    "prefix": ["trigger", "[trigger"],
    "body": "[trigger ${1|road,settlement|}]",
    "description": "Set encounter trigger location"
  },
  "Front-matter: tier": {
    "prefix": ["tier", "[tier"],
    "body": "[tier ${1|1,2,3|}]",
    "description": "Set encounter tier"
  },
  "Front-matter: vignette": {
    "prefix": ["vignette", "[vignette"],
    "body": "[vignette ${1:path}]",
    "description": "Override vignette image"
  },
  "Inscription Block": {
    "prefix": ["inscription", "\"\"\""],
    "body": [
      "\"\"\"",
      "${1:Inscription text}",
      "\"\"\""
    ],
    "description": "Triple-quoted inscription block"
  },

