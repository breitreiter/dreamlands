    { "trigger": "tier\t[tier n]", "contents": "[tier ${1:1}]" },
    { "trigger": "requires\t[requires condition]", "contents": "[requires ${1:has} ${2:id}]" },

    { "trigger": "stats\tstats section", "contents": "stats:\n  resistance ${1:8}\n  ${2:momentum ${3:3}}" },
    { "trigger": "timers\ttimers section", "contents": "timers:\n  draw ${1:2}\n  * ${2:Timer Name} [counter ${3:Counter text}]: ${4:spirits} ${5:2} every ${6:4}" },
    { "trigger": "openings\topenings section", "contents": "openings:\n  * ${1:Card Name}: ${2:free} -> ${3:damage 1}" },
