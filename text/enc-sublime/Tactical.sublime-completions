    { "trigger": "opening\t* name: cost -> effect", "contents": "* ${1:Card Name}: ${2:free} -> ${3:damage 1}" },
    { "trigger": "timer\t* name: effect every N", "contents": "* ${1:Timer Name} [counter ${2:Counter text}]: ${3:spirits} ${4:2} every ${5:4}" },
    { "trigger": "branch\t* label -> ref", "contents": "* ${1:Label} -> ${2:path/to/Encounter}" },

